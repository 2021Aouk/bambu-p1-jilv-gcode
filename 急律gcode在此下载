;开始g代码
 

M220 S100 ;速度100%
M221 S100 ;流量100%
M140 S[bed_temperature_initial_layer_single] ;设置热床温度，不等待


M17 Z0.4 ; 启用电机(降低Z马达电流)

M1002 set_gcode_claim_speed_level : 5
M221 X0 Y0 Z0 ;关闭软端限位，防止潜在的逻辑问题
G29.1 Z{+0.0} ; 首先清除z-trim值
M204 S10000 ; init ACC set to 10m/s^2

G28 X Y Z P0 T300; home z with low precision,permit 300 temperature
M104 S{nozzle_temperature_initial_layer[initial_extruder]+0} ; 喷嘴比设定高0度，不等待，使余料流净
M17 X1.2 Y1.2 Z0.75 ;将电机电流复位为默认值

M975 S1 ; 打开振动补偿

G1 X80 Y245 F20000 ;移动到马桶前面
G1 Y266 F3000 ;慢慢移到马桶里，y267就可能撞丢步，虽然再往里废料更容易进去
M1002 gcode_claim_action : 2
M106 P1 S0 ;关风扇
G29.2 S0 ;关闭ABL（自动调平）

M620 M ;AMS,好像只要用ams就会自己回厕所往前再往后
M620 S[initial_extruder]A   ; 如果AMS存在，则切换材料
    M109 S[nozzle_temperature_initial_layer] ;热端升至打印温度
    T[initial_extruder]
    M400
M621 S[initial_extruder]A
;设置在最初温度下启用ams？
M620.1 E F{filament_max_volumetric_speed[initial_extruder]/2.4053*60} T{nozzle_temperature_range_high[initial_extruder]}
;进料后，挤出设置为最大体积速度/耗材截面积*60，在最高的 设置的喷嘴温度下

M412 S1 ; 打开断料检检测===

G1 X60 Y266 F20000  ;冗余代码：防止ams不执行，挤出烧塑料
M109 S[nozzle_temperature_initial_layer] ;冗余代码：热端回至打印温度，准备冲刷
G92 E0
;G91 E
G1 E77 Z0.2 F150
G92 E0
G1 E70 F1000 ；换料不干净增加这个
G92 E0
G1 E-0.5 F3600
G1 X145 F25000 ;y太靠后丢步？
;打印头右移，擦嘴＋冲水，然后热床上抬才开始打印，这个上抬放在挤出冲刷里后，此冲水失效，原因是此处往前注释过多不执行
G1 X60 F25000 ;撞四氟管抖掉残料

M1002 gcode_claim_action : 14
G29.2 S1 ;打开ABL（自动调平），S0是关闭


;===== noozle load line ===============================
M975 S1
G90
M83
T1000
G1 X18.0 Y1.0 Z0.8 F18000;Move to start position
M109 S{nozzle_temperature_initial_layer[initial_extruder]}
G1 Z0.2
G0 E2 F300
G0 X240 E15 F{outer_wall_volumetric_speed/(0.3*0.5)     * 60}
G0 Y11 E0.700 F{outer_wall_volumetric_speed/(0.3*0.5)/ 4 * 60}
G0 X239.5
G0 E0.2
G0 Y1.5 E0.700
G0 X18 E15 F{outer_wall_volumetric_speed/(0.3*0.5)     * 60}
M400


